# 自建错误收集服务地址（可选）
# 本地部署：http://localhost:3000
# Cloudflare Workers：https://seahi-error-server.your-subdomain.workers.dev
ERROR_SERVER_URL=https://seahi-error-server.your-subdomain.workers.dev

# Sentry DSN - 从 Sentry 项目设置中获取（可选）
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# GitHub Token - 用于创建 Issue（可选，备用方案）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repo

# 环境
RUST_ENV=production
